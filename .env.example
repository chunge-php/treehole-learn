# 本地 Supabase 端口 (避免与其他项目冲突)
# API:    55421
# DB:     55422
# Studio: 55423 → http://localhost:55423
NEXT_PUBLIC_SUPABASE_URL=http://localhost:55421
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LOCAL_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgres://postgres:postgres@localhost:55422/postgres

# 生产部署时改成实际 supabase 项目地址 + key
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# 会话签名密钥 (生产必须设置)
SESSION_SECRET=treehole-dev-change-me-in-prod
