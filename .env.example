# 本地 Supabase 端口 (避免与其他项目冲突)
# API:    46421
# DB:     46422
# Studio: 46423 → http://localhost:46423
NEXT_PUBLIC_SUPABASE_URL=http://localhost:46421
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LOCAL_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgres://postgres:postgres@localhost:46422/postgres

# 生产部署时改成实际 supabase 项目地址 + key
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# 会话签名密钥 (生产必须设置)
SESSION_SECRET=treehole-dev-change-me-in-prod

# 多模态语音情绪 API (发展猫)
FAZHANMAO_URL=http://gpu.fazhanmao.com:9096/system/learning_ability/get_file_paths
# 测试语音 (一键答完/调试用, 已存在于 OBS)
FAZHANMAO_SAMPLE_AUDIO=https://aiemotion.obs.cn-north-4.myhuaweicloud.com/1/XXL0001_12-03-16-32/3bc9ed9a0bc5b8ba.wav

# 华为云 OBS (语音音频存储, S3 兼容; 路径格式 {uid}/{code}_{MM-DD-HH-mm}/x.wav)
HUAWEI_OSS_ACCESS_KEY_ID=
HUAWEI_OSS_ACCESS_KEY_SECRET=
HUAWEI_OSS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com
HUAWEI_OSS_REGION=cn-north-4
HUAWEI_COS_BUCKET=aiemotion
HUAWEI_OSS_URL_PREFIX=https://aiemotion.obs.cn-north-4.myhuaweicloud.com
